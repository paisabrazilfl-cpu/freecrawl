DATABASE_URL=postgresql://freecrawl:freecrawl@postgres:5432/freecrawl
REDIS_URL=redis://redis:6379/0
MAX_CONCURRENCY=5
REQUEST_TIMEOUT=30
MAX_CRAWL_PAGES=500
MAX_CRAWL_DEPTH=5

# Scheduled maintenance (app.cron). Cron wakes every 10 minutes.
SELF_URL=
CRON_INTERVAL_SECONDS=600
CRON_REQUEUE_AFTER_MINUTES=15
CRON_STALE_AFTER_MINUTES=30
